# 한국투자증권 Open API (https://apiportal.koreainvestment.com 에서 발급)
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ENV=real           # real | vts (모의투자)
KIS_ACCOUNT_NO=        # 계좌번호 (현재 미사용)

# 데이터베이스 (SQLite)
DATABASE_URL="file:./dev.db"

# 배포 시 필요 (로컬 개발 시 기본값 http://localhost:3000 사용)
# NEXT_PUBLIC_BASE_URL=https://your-domain.com
